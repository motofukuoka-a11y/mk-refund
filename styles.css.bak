:root{color-scheme:light;--bg:#f3f4f6;--panel:#fff;--text:#111827;--muted:#4b5563;--line:#d1d5db;--accent:#0f766e;--accent2:#115e59}[data-theme=dark]{color-scheme:dark;--bg:#0b1220;--panel:#111827;--text:#f9fafb;--muted:#cbd5e1;--line:#374151;--accent:#2dd4bf;--accent2:#14b8a6}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text);font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","Noto Sans JP",sans-serif;line-height:1.65}header{display:flex;justify-content:space-between;align-items:center;padding:22px max(16px,calc((100% - 900px)/2));background:#111827;color:#fff}header small{letter-spacing:.18em;opacity:.75}header h1{margin:0;font-size:2rem}header p{margin:.2rem 0 0;opacity:.85}main{max-width:900px;margin:24px auto;padding:0 16px}.card{background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:22px;margin-bottom:20px;box-shadow:0 8px 24px #0000000f}.card h2{margin-top:0}.muted,.reason,footer{color:var(--muted)}.grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}label{display:block;font-weight:700;margin-bottom:15px}input,select{width:100%;margin-top:6px;padding:12px;border:1px solid var(--line);border-radius:10px;background:var(--panel);color:var(--text);font:inherit}.actions{display:flex;gap:12px;margin-top:20px}button{border:0;border-radius:10px;padding:12px 20px;background:var(--accent);color:#fff;font-weight:800;cursor:pointer}button:hover{background:var(--accent2)}button.sub{background:transparent;color:inherit;border:1px solid currentColor}.hidden{display:none!important}.conditional{padding:16px;border:1px dashed var(--line);border-radius:12px;margin:12px 0}.conditional .muted{margin:0}.badge{display:inline-block;padding:6px 12px;border-radius:999px;font-weight:800;background:#d1fae5;color:#065f46}.badge.no{background:#fee2e2;color:#991b1b}.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin:16px 0}.metric{border:1px solid var(--line);border-radius:12px;padding:14px}.metric b{display:block;font-size:1.3rem}pre{white-space:pre-wrap;background:var(--bg);padding:16px;border-radius:12px;border:1px solid var(--line)}table{width:100%;border-collapse:collapse;margin-top:12px}th,td{border-bottom:1px solid var(--line);padding:9px;text-align:left}footer{max-width:900px;margin:0 auto;padding:0 16px 30px;font-size:.9rem}@media(max-width:640px){.grid{grid-template-columns:1fr}.card{padding:16px}header{padding:18px 16px}.actions{flex-direction:column}.actions button{width:100%}}
